# Local devbox env vars. Copy to .env (gitignored) and adjust if needed.
# Defaults match the docker-compose stack.

# GCP (set when working against dev/staging/prod)
GCP_PROJECT_DEV=ithina-dis-dev
GCP_REGION=asia-south1

# Local Postgres (docker-compose service)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=ithina_dis_user
POSTGRES_PASSWORD=ithina_dis_password
POSTGRES_DB=ithina_dis_db
POSTGRES_URL=postgresql+psycopg://ithina_dis_user:ithina_dis_password@localhost:5433/ithina_dis_db

# Pub/Sub emulator. PUBSUB_PROJECT_ID is required by csv-ingest-worker,
# streaming-consumer AND dis-ui-server (Slice 8: the csv.received publish).
PUBSUB_EMULATOR_HOST=localhost:8085
PUBSUB_PROJECT_ID=local-dis

# GCS emulator (fake-gcs-server). GCS_BUCKET_BRONZE is required by
# csv-ingest-worker, streaming-consumer AND dis-ui-server (Slice 8: the
# synchronous CSV upload writes the bronze object; the worker cross-checks
# the published gcs_uri against the same value, so they must agree).
STORAGE_EMULATOR_HOST=http://localhost:4443
GCS_BUCKET_BRONZE=ithina-bronze-raw
GCS_BUCKET_REPLAY=ithina-replay-staging
GCS_BUCKET_DLQ=ithina-dlq

# Redis (identity cache)
REDIS_URL=redis://localhost:6379

# Customer Master read access (for DIS Mirror Sync, DB-pull mode)
# DIS reads core.tenants and core.stores from Customer Master via the dedicated
# read-only role dis_mirror_reader (created by
# infra/customer-master/create-dis-mirror-reader.sql).
# RLS is enforced: mirror-sync code sets app.user_type='PLATFORM' and
# app.tenant_id=NULL per Customer Master's read-access contract.
# Local: CM Postgres on 5432 (separate from DIS Postgres on 5433).
# Cloud: CM Cloud SQL host; rotate password or switch to IAM auth.
CM_DB_HOST=localhost
CM_DB_PORT=5432
CM_DB_NAME=ithina_platform_db
CM_DB_USER=dis_mirror_reader
CM_DB_PASSWORD=dev-only-rotate-in-cloud
CM_DB_URL=postgresql://dis_mirror_reader:dev-only-rotate-in-cloud@localhost:5432/ithina_platform_db

# Identity Service fake
IDENTITY_SERVICE_URL=http://localhost:8081

# Customer Master fake
CUSTOMER_MASTER_URL=http://localhost:8082

# Customer Master JWT verification config.
# PROVISIONAL (Slice 2 R2): the Customer Master contract is not yet signed off.
# These values mirror the CM fake's example JWT (issuer/audience/JWKS path) so the
# consumer verification path can be exercised. Revisit when the CM contract lands.
CM_JWKS_URL=http://localhost:8082/.well-known/jwks.json
CM_JWT_ISSUER=https://customer-master.local
CM_JWT_AUDIENCE=dis

# Admin role (for migrations only; NOT for service code)
POSTGRES_ADMIN_URL=postgresql+psycopg://ithina_dis_admin:ithina_dis_admin_password@localhost:5433/ithina_dis_db
