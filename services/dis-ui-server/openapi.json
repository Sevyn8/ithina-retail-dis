      "MappingTemplatePatch": {
        "properties": {
          "template_name": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 200,
                "minLength": 1
              },
              {
                "type": "null"
              }
            ],
            "title": "Template Name"
          },
          "mapping_rules": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Mapping Rules"
          }
        },
        "type": "object",
        "title": "MappingTemplatePatch",
        "description": "``PATCH /mapping-templates/{template_id}`` body — at least one field present.\n\n``template_name`` renames the LINEAGE (all version rows; D17 immutability\ncovers version content, not the lineage label). ``mapping_rules`` edits the\nDRAFT in place, or mints a new DRAFT version chained to the STAGED/ACTIVE\nhead when none exists."
      },
      "MappingTemplateVersion": {
        "properties": {
          "mapping_version_id": {
            "type": "integer",
            "title": "Mapping Version Id"
          },
          "version": {
            "type": "integer",
            "title": "Version"
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "staged",
              "active",
              "deprecated"
