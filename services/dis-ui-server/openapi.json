          "template_name",
          "mapping_rules"
        ],
        "title": "MappingTemplateCreate",
        "description": "``POST /mapping-templates`` body. v1 is hand-authored: the operator supplies\nthe ``source_id`` (validated well-formed only — no source registry exists, a\ndeliberate slice limit) and the full D49 rules document."
      },
      "MappingTemplateDetail": {
        "properties": {
          "template_id": {
            "type": "string",
