# dis-ui environment variables (Vite). Copy to .env.local for local overrides.
# .env files are git-ignored; this example is the committed documentation.

# Which dis-ui-server data source the UI uses.
#   fixture (default) - inlined fixture data, no backend call (slice 19).
#   real              - calls dis-ui-server (wired but not implemented in slice 19).
# Any value other than "real" is treated as "fixture".
VITE_DIS_UI_SERVER_MODE=fixture

# Base URL of dis-ui-server. Unused in fixture mode; REQUIRED in real mode.
# Never hardcode localhost in source; configure it here per environment.
# VITE_DIS_UI_SERVER_BASE_URL=https://dis-ui-server.example
